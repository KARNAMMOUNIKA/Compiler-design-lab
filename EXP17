#include <stdio.h>
#include <string.h>
#include <ctype.h>

char prod[10][20];
char leading[10][20];
int n;

int indexNT(char c)
{
    return c-'A';
}

void addLeading(char nt,char ch)
{
    int i=indexNT(nt);

    if(strchr(leading[i],ch)==NULL)
    {
        int len=strlen(leading[i]);
        leading[i][len]=ch;
        leading[i][len+1]='\0';
    }
}

int main()
{
    int i,j,changed;

    printf("Enter number of productions: ");
    scanf("%d",&n);

    printf("Enter productions:\n");

    for(i=0;i<n;i++)
        scanf("%s",prod[i]);

    do
    {
        changed=0;

        for(i=0;i<n;i++)
        {
            char lhs=prod[i][0];
            char *rhs=&prod[i][2];

            if(!isupper(rhs[0]))
            {
                int len=strlen(leading[indexNT(lhs)]);

                addLeading(lhs,rhs[0]);

                if(len!=strlen(leading[indexNT(lhs)]))
                    changed=1;
            }
            else
            {
                int k=indexNT(rhs[0]);

                for(j=0;leading[k][j];j++)
                {
                    int len=strlen(leading[indexNT(lhs)]);

                    addLeading(lhs,leading[k][j]);

                    if(len!=strlen(leading[indexNT(lhs)]))
                        changed=1;
                }

                if(rhs[1] && !isupper(rhs[1]))
                {
                    int len=strlen(leading[indexNT(lhs)]);

                    addLeading(lhs,rhs[1]);

                    if(len!=strlen(leading[indexNT(lhs)]))
                        changed=1;
                }
            }
        }

    }while(changed);

    printf("\nLEADING Sets\n");

    for(i=0;i<26;i++)
    {
        if(strlen(leading[i]))
        {
            printf("%c : { ",i+'A');

            for(j=0;leading[i][j];j++)
                printf("%c ",leading[i][j]);

            printf("}\n");
        }
    }

    return 0;
}
