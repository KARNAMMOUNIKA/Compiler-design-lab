#include <stdio.h>
#include <string.h>

struct symbol
{
    char name[20];
    char type[20];
};

struct symbol table[50];
int count = 0;

void insert()
{
    printf("Identifier: ");
    scanf("%s", table[count].name);

    printf("Type: ");
    scanf("%s", table[count].type);

    count++;
}

void display()
{
    int i;

    printf("\nSymbol Table\n");
    printf("-----------------------\n");

    for(i=0;i<count;i++)
    {
        printf("%s\t%s\n",
               table[i].name,
               table[i].type);
    }
}

void search()
{
    char id[20];
    int i, found=0;

    printf("Enter identifier: ");
    scanf("%s", id);

    for(i=0;i<count;i++)
    {
        if(strcmp(id,table[i].name)==0)
        {
            printf("Found : %s %s\n",
                   table[i].name,
                   table[i].type);
            found=1;
        }
    }

    if(!found)
        printf("Not Found\n");
}

int main()
{
    int ch;

    while(1)
    {
        printf("\n1.Insert\n2.Display\n3.Search\n4.Exit\n");
        scanf("%d",&ch);

        switch(ch)
        {
            case 1: insert(); break;
            case 2: display(); break;
            case 3: search(); break;
            case 4: return 0;
        }
    }
}
