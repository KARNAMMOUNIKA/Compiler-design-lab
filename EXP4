#include <stdio.h>

int main()
{
    char op;

    printf("Enter operator: ");
    scanf("%c",&op);

    switch(op)
    {
        case '+':
        case '-':
        case '*':
        case '/':
            printf("Valid Arithmetic Operator\n");
            break;

        default:
            printf("Invalid Operator\n");
    }

    return 0;
}
