#include <stdio.h>
#include <string.h>

int main()
{
    char prod[50], alpha[50], beta[50];
    char lhs;

    printf("Enter production (Example: A->Aa|b): ");
    scanf("%s", prod);

    lhs = prod[0];

    char *arrow = strstr(prod, "->");
    char *rhs = arrow + 2;

    char *pipe = strchr(rhs, '|');

    char first[20], second[20];

    strncpy(first, rhs, pipe - rhs);
    first[pipe - rhs] = '\0';

    strcpy(second, pipe + 1);

    if(first[0] == lhs)
    {
        strcpy(alpha, first + 1);
        strcpy(beta, second);

        printf("\nGrammar after removing Left Recursion:\n");

        printf("%c->%s%c'\n", lhs, beta, lhs);
        printf("%c'->%s%c'|ε\n", lhs, alpha, lhs);
    }
    else if(second[0] == lhs)
    {
        strcpy(alpha, second + 1);
        strcpy(beta, first);

        printf("\nGrammar after removing Left Recursion:\n");

        printf("%c->%s%c'\n", lhs, beta, lhs);
        printf("%c'->%s%c'|ε\n", lhs, alpha, lhs);
    }
    else
    {
        printf("No Left Recursion Found.\n");
    }

    return 0;
}
