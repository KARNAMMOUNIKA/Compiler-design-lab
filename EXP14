#include<stdio.h>
#include<string.h>

int main()
{
    char exp[50];
    int i=0,temp=1;

    printf("Enter Expression: ");
    scanf("%s",exp);

    while(strchr(exp,'*') || strchr(exp,'/') ||
          strchr(exp,'+') || strchr(exp,'-'))
    {
        for(i=0;exp[i];i++)
        {
            if(exp[i]=='*' || exp[i]=='/')
            {
                printf("t%d = %c %c %c\n",
                       temp,
                       exp[i-1],
                       exp[i],
                       exp[i+1]);

                exp[i-1]='t';
                exp[i]='0'+temp;

                memmove(&exp[i+1],
                        &exp[i+2],
                        strlen(exp)-i);

                temp++;
                break;
            }
        }

        for(i=0;exp[i];i++)
        {
            if(exp[i]=='+' || exp[i]=='-')
            {
                printf("t%d = %c %c %c\n",
                       temp,
                       exp[i-1],
                       exp[i],
                       exp[i+1]);

                exp[i-1]='t';
                exp[i]='0'+temp;

                memmove(&exp[i+1],
                        &exp[i+2],
                        strlen(exp)-i);

                temp++;
                break;
            }
        }
    }

    return 0;
}
