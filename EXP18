#include <stdio.h>
#include <string.h>
#include <ctype.h>

char prod[10][20];
char trailing[10][20];
int n;

int indexNT(char c)
{
    return c-'A';
}

void addTrailing(char nt,char ch)
{
    int i=indexNT(nt);

    if(strchr(trailing[i],ch)==NULL)
    {
        int len=strlen(trailing[i]);
        trailing[i][len]=ch;
        trailing[i][len+1]='\0';
    }
}

int main()
{
    int i,j,changed;

    printf("Enter number of productions: ");
    scanf("%d",&n);

    printf("Enter productions:\n");

    for(i=0;i<n;i++)
        scanf("%s",prod[i]);

    do
    {
        changed=0;

        for(i=0;i<n;i++)
        {
            char lhs=prod[i][0];
            char *rhs=&prod[i][2];

            int lenrhs=strlen(rhs);

            if(!isupper(rhs[lenrhs-1]))
            {
                int len=strlen(trailing[indexNT(lhs)]);

                addTrailing(lhs,rhs[lenrhs-1]);

                if(len!=strlen(trailing[indexNT(lhs)]))
                    changed=1;
            }
            else
            {
                int k=indexNT(rhs[lenrhs-1]);

                for(j=0;trailing[k][j];j++)
                {
                    int len=strlen(trailing[indexNT(lhs)]);

                    addTrailing(lhs,trailing[k][j]);

                    if(len!=strlen(trailing[indexNT(lhs)]))
                        changed=1;
                }

                if(lenrhs>=2 && !isupper(rhs[lenrhs-2]))
                {
                    int len=strlen(trailing[indexNT(lhs)]);

                    addTrailing(lhs,rhs[lenrhs-2]);

                    if(len!=strlen(trailing[indexNT(lhs)]))
                        changed=1;
                }
            }
        }

    }while(changed);

    printf("\nTRAILING Sets\n");

    for(i=0;i<26;i++)
    {
        if(strlen(trailing[i]))
        {
            printf("%c : { ",i+'A');

            for(j=0;trailing[i][j];j++)
                printf("%c ",trailing[i][j]);

            printf("}\n");
        }
    }

    return 0;
}
